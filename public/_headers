# Hashed assets (content-versioned filename = cache forever)
/_astro/*
  Cache-Control: public, max-age=31536000, immutable

# Static images (also content-versioned or rare changes)
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable

# HTML pages — revalidate so edits go live quickly
/*.html
  Cache-Control: public, max-age=0, must-revalidate

/404.html
  Cache-Control: public, max-age=0, must-revalidate

# Sitemap — short cache
/sitemap-index.xml
  Cache-Control: public, max-age=3600, must-revalidate

# Security headers for everything
/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Strict-Transport-Security: max-age=31536000; includeSubDomains; preload

# Admin and API need unsafe-none COOP so OAuth popup can communicate via window.opener
/admin/*
  Cross-Origin-Opener-Policy: unsafe-none

/api/*
  Cross-Origin-Opener-Policy: unsafe-none
