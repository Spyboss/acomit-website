---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import { ICON_PATHS } from "../data/icons";

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Services">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="pt-32 pb-16 gradient-purple relative overflow-hidden">
    <div class="absolute top-20 right-20 w-64 h-64 rounded-full bg-primary-400/5 blur-3xl"></div>
    <div class="absolute bottom-10 left-10 w-80 h-80 rounded-full bg-accent-500/5 blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-extrabold text-white" data-aos="fade-up">Our Services</h1>
      <p class="mt-4 text-lg text-primary-200 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
        End-to-end technology solutions tailored for Sri Lankan businesses
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 space-y-24">
      {services.map((service, i) => (
        <div class={`grid gap-12 items-center ${i % 2 === 0 ? "lg:grid-cols-[1.2fr_1fr]" : "lg:grid-cols-[1fr_1.2fr]"}`} data-aos="fade-up">
          <div class={i % 2 === 0 ? "order-1" : "order-1 lg:order-2"}>
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-primary-100 text-primary-600 mb-6">
              <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={ICON_PATHS[service.data.icon]} /></svg>
            </div>
            <h2 class="font-display text-3xl font-bold text-gray-900">{service.data.title}</h2>
            <p class="mt-2 text-lg text-primary-600 font-medium">{service.data.subtitle}</p>
            <p class="mt-4 text-gray-600 leading-relaxed">{service.data.description}</p>
            <div class="grid gap-3 mt-8 sm:grid-cols-2">
              {service.data.features.map((f: string) => (
                <div class="flex items-center gap-3">
                  <svg class="w-5 h-5 text-primary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                  <span class="text-sm text-gray-700">{f}</span>
                </div>
              ))}
            </div>
            <a href="/contact" class="btn-primary mt-8">Discuss Your Project</a>
          </div>
          <div class={`${i % 2 === 0 ? "order-2" : "order-2 lg:order-1"}`}>
            <div class="relative">
              <div class="aspect-[4/3] rounded-2xl bg-gradient-to-br from-primary-100 to-primary-50 border border-primary-100 flex items-center justify-center p-8">
                <div class="text-center">
                  <svg class="w-24 h-24 mx-auto text-primary-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d={ICON_PATHS[service.data.icon]} /></svg>
                </div>
              </div>
              <div class="absolute -bottom-4 -right-4 w-full h-full rounded-2xl border-2 border-primary-200 -z-10"></div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4 text-center" data-aos="fade-up">
      <h2 class="font-display text-3xl font-bold text-gray-900">Need a Custom Solution?</h2>
      <p class="mt-3 text-gray-600 max-w-xl mx-auto">
        Don't see exactly what you're looking for? We build custom software tailored to your specific requirements.
      </p>
      <a href="/contact" class="btn-primary mt-8">Get in Touch</a>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
