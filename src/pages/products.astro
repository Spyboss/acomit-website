---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { getCollection } from "astro:content";
import { ICON_PATHS } from "../data/icons";
import { PRODUCT_COLORS } from "../data/colors";

const products = (await getCollection("products")).sort((a, b) => a.data.order - b.data.order);
---

<BaseLayout title="Products">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="pt-32 pb-16 gradient-purple relative overflow-hidden">
    <div class="absolute top-10 left-1/3 w-72 h-72 rounded-full bg-primary-400/5 blur-3xl"></div>
    <div class="absolute bottom-0 right-10 w-96 h-96 rounded-full bg-primary-400/5 blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-extrabold text-white" data-aos="fade-up">Our Products</h1>
      <p class="mt-4 text-lg text-primary-200 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
        Ready-to-deploy software solutions trusted by Sri Lankan businesses
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4 space-y-16">
      {products.map((product) => {
        const c = PRODUCT_COLORS[product.data.color] || PRODUCT_COLORS.blue;
        return (
          <div
            class={`rounded-2xl border ${c.border} ${c.bg} overflow-hidden card-hover`}
            data-aos="fade-up"
          >
            <div class="p-8 md:p-12">
              <div class="grid gap-8 md:grid-cols-[1fr_1.5fr]">
                <div>
                  <div class={`inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-gradient-to-br ${c.gradient} text-white mb-5`}>
                    <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 256 256"><path d={ICON_PATHS[product.data.icon]} /></svg>
                  </div>
                  <h2 class="font-display text-2xl font-bold text-gray-900">{product.data.title}</h2>
                  <p class={`mt-1 text-sm font-medium ${c.text}`}>{product.data.tagline}</p>
                  <p class="mt-4 text-gray-600 leading-relaxed">{product.data.description}</p>
                </div>
                <div>
                  <h3 class="font-semibold text-gray-900 mb-4">Key Features</h3>
                  <div class="grid gap-3 sm:grid-cols-2">
                    {product.data.features.map((f: string) => (
                      <div class="flex items-start gap-2.5">
                        <svg class={`w-5 h-5 ${c.text} flex-shrink-0 mt-0.5`} fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd" /></svg>
                        <span class="text-sm text-gray-700">{f}</span>
                      </div>
                    ))}
                  </div>
                  <a href="/contact" class={`inline-flex items-center gap-2 mt-6 px-5 py-2.5 text-sm font-semibold text-white rounded-lg bg-gradient-to-r ${c.gradient} hover:shadow-lg transition-all active:scale-95`}>
                    Request a Demo
                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 256 256"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z" /></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        );
      })}
    </div>
  </section>

  <section class="py-20 gradient-purple">
    <div class="max-w-7xl mx-auto px-4 text-center" data-aos="fade-up">
      <h2 class="font-display text-3xl font-bold text-white">Interested in a Product?</h2>
      <p class="mt-3 text-primary-200 max-w-xl mx-auto">
        Contact us for a live demo and see how our software can transform your business operations.
      </p>
      <a href="/contact" class="btn-accent mt-8">Schedule a Demo</a>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
