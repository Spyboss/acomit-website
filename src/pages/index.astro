---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import HeroSection from "../components/HeroSection.astro";
import ServicesSection from "../components/ServicesSection.astro";
import ProductsSection from "../components/ProductsSection.astro";
import AboutSection from "../components/AboutSection.astro";
import ClientLogos from "../components/ClientLogos.astro";
import ContactSection from "../components/ContactSection.astro";
import { getEntry } from "astro:content";

const home = await getEntry("settings", "home");
const { hero_title, hero_subtitle } = home.data;
---

<BaseLayout>
  <Fragment slot="header">
    <Header />
  </Fragment>

  <HeroSection heroTitle={hero_title} heroSubtitle={hero_subtitle} />
  <ServicesSection />
  <ProductsSection />
  <AboutSection />
  <ClientLogos />
  <ContactSection />

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
