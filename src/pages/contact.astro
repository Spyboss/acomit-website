---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Contact">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="pt-32 pb-16 gradient-purple relative overflow-hidden">
    <div class="absolute top-20 right-1/4 w-72 h-72 rounded-full bg-primary-400/5 blur-3xl"></div>
    <div class="absolute bottom-0 left-10 w-80 h-80 rounded-full bg-primary-400/5 blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-extrabold text-white" data-aos="fade-up">Contact Us</h1>
      <p class="mt-4 text-lg text-primary-200 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
        Ready to start your next project? Get in touch with us today.
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid items-start gap-16 lg:grid-cols-2">
        <div data-aos="fade-right">
          <h2 class="font-display text-3xl font-bold text-gray-900">Let's Talk About Your Project</h2>
          <p class="mt-4 text-gray-600 leading-relaxed">
            Whether you need a custom software solution, a new website, a mobile app, or one of our ready-made products — we're here to help. Fill out the form and we'll get back to you within 24 hours.
          </p>
          <div class="mt-12 space-y-8">
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 flex items-center justify-center w-14 h-14 rounded-xl bg-primary-100 text-primary-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Email</h3>
                <p class="mt-1 text-gray-500">Drop us a line anytime</p>
                <a href="mailto:info@acomit.lk" class="text-primary-600 hover:text-primary-700 font-medium transition-colors">info@acomit.lk</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 flex items-center justify-center w-14 h-14 rounded-xl bg-primary-100 text-primary-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Phone</h3>
                <p class="mt-1 text-gray-500">Mon-Fri 9am-5pm</p>
                <a href="tel:+94472262263" class="text-primary-600 hover:text-primary-700 font-medium transition-colors">+94 47 2 262 263</a>
              </div>
            </div>
            <div class="flex items-start gap-4">
              <div class="flex-shrink-0 flex items-center justify-center w-14 h-14 rounded-xl bg-primary-100 text-primary-600">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              </div>
              <div>
                <h3 class="font-semibold text-gray-900">Location</h3>
                <p class="mt-1 text-gray-500">Sri Lanka</p>
              </div>
            </div>
          </div>
        </div>
        <div data-aos="fade-left">
          <div class="p-8 rounded-2xl bg-gray-50 border border-gray-100">
            <h3 class="text-xl font-bold text-gray-900 font-display mb-6">Send Us a Message</h3>
            <form action="https://formsubmit.co/info@acomit.lk" method="POST" class="space-y-5">
              <input type="hidden" name="_subject" value="New enquiry from acomit.lk contact page" />
              <input type="hidden" name="_captcha" value="false" />
              <input type="text" name="_honey" style="display:none" />
              <div class="grid gap-5 sm:grid-cols-2">
                <div>
                  <label for="name" class="block text-sm font-medium text-gray-700 mb-1.5">Your Name *</label>
                  <input type="text" id="name" name="name" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none text-sm" placeholder="John Doe" />
                </div>
                <div>
                  <label for="email" class="block text-sm font-medium text-gray-700 mb-1.5">Email *</label>
                  <input type="email" id="email" name="email" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none text-sm" placeholder="john@example.com" />
                </div>
              </div>
              <div>
                <label for="phone" class="block text-sm font-medium text-gray-700 mb-1.5">Phone</label>
                <input type="tel" id="phone" name="phone" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none text-sm" placeholder="+94 XX XXX XXXX" />
              </div>
              <div>
                <label for="company" class="block text-sm font-medium text-gray-700 mb-1.5">Company</label>
                <input type="text" id="company" name="company" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none text-sm" placeholder="Your business name" />
              </div>
              <div>
                <label for="service" class="block text-sm font-medium text-gray-700 mb-1.5">I'm interested in</label>
                <select id="service" name="service" class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-gray-900 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none text-sm">
                  <option value="">Select a service...</option>
                  <option value="software">Software Solutions</option>
                  <option value="web">Web Solutions</option>
                  <option value="mobile">Mobile Solutions</option>
                  <option value="inventory">Inventory Management System</option>
                  <option value="pos">POS Billing System</option>
                  <option value="welfare">Welfare Management System</option>
                  <option value="credit-card">Credit Card Comparator</option>
                  <option value="other">Other</option>
                </select>
              </div>
              <div>
                <label for="message" class="block text-sm font-medium text-gray-700 mb-1.5">Message *</label>
                <textarea id="message" name="message" rows="4" required class="w-full px-4 py-3 rounded-xl border border-gray-200 bg-white text-gray-900 placeholder-gray-400 focus:ring-2 focus:ring-primary-500 focus:border-transparent transition-all outline-none text-sm resize-none" placeholder="Tell us about your project..."></textarea>
              </div>
              <button type="submit" class="btn-primary w-full justify-center">
                Send Message
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8" /></svg>
              </button>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
