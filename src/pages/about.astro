---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="About">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="pt-32 pb-16 gradient-purple relative overflow-hidden">
    <div class="absolute top-10 left-1/4 w-80 h-80 rounded-full bg-primary-400/5 blur-3xl"></div>
    <div class="absolute bottom-0 right-20 w-64 h-64 rounded-full bg-primary-400/5 blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-extrabold text-white" data-aos="fade-up">About Acom IT</h1>
      <p class="mt-4 text-lg text-primary-200 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
        Empowering Sri Lankan businesses with technology since 2015
      </p>
    </div>
  </section>

  <section class="py-20 bg-white">
    <div class="max-w-7xl mx-auto px-4">
      <div class="grid gap-16 lg:grid-cols-2 items-center" data-aos="fade-up">
        <div>
          <span class="inline-block px-4 py-1.5 text-sm font-medium rounded-full text-primary-700 bg-primary-100 mb-4">Our Story</span>
          <h2 class="font-display text-3xl font-bold text-gray-900">Who We Are</h2>
          <p class="mt-6 text-gray-600 leading-relaxed">
            Acom Information Technology focuses on helping various businesses start and market their businesses on the Web, enabling them to realize their dreams of self-reliance, entrepreneurship, creativity, and financial independence.
          </p>
          <p class="mt-4 text-gray-600 leading-relaxed">
            We pioneered the service for creating and acquiring specific technology and today offer a full range of software-related services. From design resources to end-to-end support services, we provide more value and innovation to our customers.
          </p>
          <p class="mt-4 text-gray-600 leading-relaxed">
            We serve numerous value-added information technology solutions to large and medium-scale organizations in Sri Lanka.
          </p>
        </div>
        <div class="relative">
          <div class="aspect-square rounded-2xl bg-gradient-to-br from-primary-100 to-primary-50 border border-primary-100 flex items-center justify-center p-12">
            <div class="text-center">
              <div class="text-5xl font-bold text-gradient font-display md:text-7xl lg:text-8xl">2015</div>
              <p class="mt-4 text-gray-500">Founded with a mission to digitize Sri Lankan businesses</p>
            </div>
          </div>
          <div class="absolute -bottom-4 -right-4 w-full h-full rounded-2xl border-2 border-primary-200 -z-10"></div>
        </div>
      </div>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-7xl mx-auto px-4">
      <div class="text-center" data-aos="fade-up">
        <h2 class="font-display text-3xl font-bold text-gray-900">Our Competitive Edge</h2>
        <p class="mt-3 text-gray-600 max-w-2xl mx-auto">
          What sets us apart in the Sri Lankan IT landscape
        </p>
      </div>
      <div class="grid gap-6 mt-12 md:grid-cols-2 lg:grid-cols-3">
        <div class="p-6 rounded-xl bg-white border border-gray-100 card-hover" data-aos="fade-up">
          <div class="w-12 h-12 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" /><path d="m9 12 2 2 4-4" /></svg>
          </div>
          <h3 class="font-semibold text-gray-900">Commitment to Customer Satisfaction</h3>
          <p class="mt-2 text-sm text-gray-600">We prioritize your success. Every solution is built with your business goals at the center.</p>
        </div>
        <div class="p-6 rounded-xl bg-white border border-gray-100 card-hover" data-aos="fade-up" data-aos-delay="100">
          <div class="w-12 h-12 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z" /></svg>
          </div>
          <h3 class="font-semibold text-gray-900">Innovation & Strategy</h3>
          <p class="mt-2 text-sm text-gray-600">We combine IT strategy with business unit strategy to deliver solutions that drive real results.</p>
        </div>
        <div class="p-6 rounded-xl bg-white border border-gray-100 card-hover" data-aos="fade-up" data-aos-delay="200">
          <div class="w-12 h-12 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><circle cx="12" cy="12" r="10" /><path d="M16 8h-6a2 2 0 1 0 0 4h4a2 2 0 1 1 0 4H8" /><path d="M12 18V6" /></svg>
          </div>
          <h3 class="font-semibold text-gray-900">Low Cost, High Quality</h3>
          <p class="mt-2 text-sm text-gray-600">We deliver enterprise-grade solutions at affordable rates, making technology accessible for every business.</p>
        </div>
        <div class="p-6 rounded-xl bg-white border border-gray-100 card-hover" data-aos="fade-up" data-aos-delay="300">
          <div class="w-12 h-12 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5" /><path d="M9 18h6" /><path d="M10 22h4" /></svg>
          </div>
          <h3 class="font-semibold text-gray-900">Vertical Integration</h3>
          <p class="mt-2 text-sm text-gray-600">End-to-end capabilities mean we handle everything from design to deployment and support.</p>
        </div>
        <div class="p-6 rounded-xl bg-white border border-gray-100 card-hover" data-aos="fade-up" data-aos-delay="400">
          <div class="w-12 h-12 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" /><path d="M16 3.128a4 4 0 0 1 0 7.744" /><path d="M22 21v-2a4 4 0 0 0-3-3.87" /><circle cx="9" cy="7" r="4" /></svg>
          </div>
          <h3 class="font-semibold text-gray-900">Experienced Team</h3>
          <p class="mt-2 text-sm text-gray-600">Years of collective experience across software, web, and mobile technologies.</p>
        </div>
        <div class="p-6 rounded-xl bg-white border border-gray-100 card-hover" data-aos="fade-up" data-aos-delay="500">
          <div class="w-12 h-12 rounded-lg bg-primary-100 text-primary-600 flex items-center justify-center mb-4">
            <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-linecap="round" stroke-linejoin="round" stroke-width="2"><path d="M3 12a9 9 0 0 1 9-9 9.75 9.75 0 0 1 6.74 2.74L21 8" /><path d="M21 3v5h-5" /><path d="M21 12a9 9 0 0 1-9 9 9.75 9.75 0 0 1-6.74-2.74L3 16" /><path d="M8 16H3v5" /></svg>
          </div>
          <h3 class="font-semibold text-gray-900">Continuous Support</h3>
          <p class="mt-2 text-sm text-gray-600">We don't just build and leave. Our team provides ongoing support to ensure your systems run smoothly.</p>
        </div>
      </div>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
