---
import BaseLayout from "../layouts/BaseLayout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<BaseLayout title="Client Login">
  <Fragment slot="header">
    <Header />
  </Fragment>

  <section class="pt-32 pb-16 gradient-purple relative overflow-hidden">
    <div class="absolute top-10 right-20 w-72 h-72 rounded-full bg-primary-400/5 blur-3xl"></div>
    <div class="absolute bottom-0 left-1/3 w-80 h-80 rounded-full bg-primary-400/5 blur-3xl"></div>
    <div class="relative z-10 max-w-7xl mx-auto px-4 text-center">
      <h1 class="font-display text-4xl md:text-5xl font-extrabold text-white" data-aos="fade-up">Client Portal</h1>
      <p class="mt-4 text-lg text-primary-200 max-w-2xl mx-auto" data-aos="fade-up" data-aos-delay="100">
        Access your business management systems
      </p>
    </div>
  </section>

  <section class="py-20 bg-gray-50">
    <div class="max-w-5xl mx-auto px-4">
      <div class="grid gap-8 md:grid-cols-3" data-aos="fade-up">
        <a
          href="/ums"
          class="group p-8 rounded-2xl bg-white border border-gray-100 card-hover text-center"
        >
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-primary-500 to-primary-700 text-white mb-6 group-hover:animate-glow">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
          </div>
          <h2 class="text-xl font-bold text-gray-900 font-display group-hover:text-primary-600 transition-colors">Hirupama Distribution</h2>
          <p class="mt-2 text-sm text-gray-500">Inventory & business management portal</p>
          <span class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-primary-600 group-hover:gap-3 transition-all">
            Access Portal
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>

        <a
          href="/dayan"
          class="group p-8 rounded-2xl bg-white border border-gray-100 card-hover text-center"
        >
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-green-500 to-green-700 text-white mb-6 group-hover:animate-glow">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
          </div>
          <h2 class="text-xl font-bold text-gray-900 font-display group-hover:text-green-600 transition-colors">Dayan Tyre</h2>
          <p class="mt-2 text-sm text-gray-500">Tyre & auto parts management portal</p>
          <span class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-green-600 group-hover:gap-3 transition-all">
            Access Portal
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>

        <a
          href="/downloads"
          class="group p-8 rounded-2xl bg-white border border-gray-100 card-hover text-center"
        >
          <div class="inline-flex items-center justify-center w-20 h-20 rounded-2xl bg-gradient-to-br from-accent-500 to-accent-700 text-white mb-6 group-hover:animate-glow">
            <svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.066 2.573c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.573 1.066c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.066-2.573c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          </div>
          <h2 class="text-xl font-bold text-gray-900 font-display group-hover:text-accent-600 transition-colors">IT Admin</h2>
          <p class="mt-2 text-sm text-gray-500">System administration & downloads</p>
          <span class="inline-flex items-center gap-2 mt-4 text-sm font-semibold text-accent-600 group-hover:gap-3 transition-all">
            Access Portal
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </span>
        </a>
      </div>

      <div class="mt-16 p-8 rounded-2xl bg-white border border-gray-100 text-center" data-aos="fade-up">
        <h2 class="font-display text-2xl font-bold text-gray-900">Don't have an account yet?</h2>
        <p class="mt-3 text-gray-600 max-w-lg mx-auto">
          These portals are for existing Acom IT clients. If you're interested in our software solutions for your business, get in touch with us.
        </p>
        <a href="/contact" class="btn-primary mt-6">Contact Us</a>
      </div>
    </div>
  </section>

  <Fragment slot="footer">
    <Footer />
  </Fragment>
</BaseLayout>
