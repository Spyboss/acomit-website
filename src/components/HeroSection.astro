---
export interface Props {
  heroTitle: string;
  heroSubtitle: string;
}

const { heroTitle, heroSubtitle } = Astro.props;
---

<section class="relative min-h-screen flex items-center pt-24 overflow-hidden gradient-purple" id="hero">
  <div class="absolute inset-0 overflow-hidden">
    <div class="absolute -top-40 -right-40 w-80 h-80 rounded-full bg-primary-500/15 blur-3xl"></div>
    <div class="absolute -bottom-40 -left-40 w-96 h-96 rounded-full bg-accent-500/15 blur-3xl"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[650px] h-[650px] rounded-full bg-primary-500/10 blur-3xl"></div>
  </div>

  <div class="relative z-10 max-w-7xl mx-auto px-4 py-20 w-full">
    <div class="grid items-center gap-12 lg:grid-cols-[1fr_1.05fr]">
      <div data-aos="fade-right">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 mb-6 text-sm font-medium rounded-full text-primary-200 bg-primary-800/50 border border-primary-700/50">
          <span class="w-2 h-2 rounded-full bg-accent-400 animate-pulse"></span>
          Trusted Since 2015
        </div>
        <h1 class="font-display text-4xl md:text-5xl lg:text-6xl font-extrabold text-white leading-tight">
          {heroTitle}
        </h1>
        <p class="mt-6 text-lg leading-relaxed text-primary-200 max-w-xl">
          {heroSubtitle}
        </p>
        <div class="flex flex-wrap gap-4 mt-8">
          <a href="/services" class="btn-primary">
            Explore Services
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a href="/contact" class="btn-outline">Get a Quote</a>
        </div>
        <div class="flex items-center gap-8 mt-12">
          <div>
            <div class="text-2xl font-bold text-white">9+</div>
            <div class="text-sm text-primary-300">Years Experience</div>
          </div>
          <div class="w-px h-10 bg-primary-700"></div>
          <div>
            <div class="text-2xl font-bold text-white">50+</div>
            <div class="text-sm text-primary-300">Projects Delivered</div>
          </div>
          <div class="w-px h-10 bg-primary-700"></div>
          <div>
            <div class="text-2xl font-bold text-white">100%</div>
            <div class="text-sm text-primary-300">Client Satisfaction</div>
          </div>
        </div>
      </div>
      <div data-aos="fade-left" class="relative min-h-[430px] lg:min-h-[560px]">
        <div class="absolute inset-0 rounded-[2rem] bg-white/[0.03] border border-white/10 shadow-2xl shadow-primary-950/40 backdrop-blur-sm"></div>
        <canvas id="hero-canvas" class="relative z-10 block w-full h-[430px] lg:h-[560px]"></canvas>
        <div class="absolute bottom-5 left-5 right-5 z-20 hidden rounded-2xl border border-white/10 bg-primary-950/50 px-5 py-4 text-primary-100 backdrop-blur-md md:block">
          <div class="text-sm font-semibold text-white">Custom systems connected end-to-end</div>
          <div class="mt-1 text-xs text-primary-300">Software, web, mobile and business operations working as one platform.</div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  @media (prefers-reduced-motion: reduce) {
    #hero-canvas {
      opacity: 0.75;
    }
  }
</style>

<script>
  const canvas = document.getElementById("hero-canvas") as HTMLCanvasElement | null;
  if (canvas) {
    const init = async () => {
      const { initHeroScene } = await import("./heroScene");
      initHeroScene(canvas);
    };
    if (document.readyState === "loading") {
      document.addEventListener("DOMContentLoaded", init, { once: true });
    } else {
      init();
    }
  }
</script>
