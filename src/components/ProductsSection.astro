---
import { getCollection } from "astro:content";
import { ICON_PATHS } from "../data/icons";
import { PRODUCT_COLORS } from "../data/colors";

const products = (await getCollection("products")).sort((a, b) => a.data.order - b.data.order);
---

<section class="py-24 bg-gray-50" id="products">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto" data-aos="fade-up">
      <span class="inline-block px-4 py-1.5 text-sm font-medium rounded-full text-primary-700 bg-primary-100 mb-4">Our Products</span>
      <h2 class="section-title">Software Built for Sri Lankan Business</h2>
      <p class="section-subtitle mx-auto">
        Ready-to-deploy solutions that solve real problems. Used by businesses across the country.
      </p>
    </div>
    <div class="grid gap-8 mt-16 md:grid-cols-2">
      {products.map((product, index) => {
        const c = PRODUCT_COLORS[product.data.color] || PRODUCT_COLORS.blue;
        return (
          <div
            class="group relative overflow-hidden rounded-2xl bg-white border border-gray-100 card-hover"
            data-aos="fade-up"
            data-aos-delay={index * 100}
          >
            <div class={`absolute top-0 right-0 w-32 h-32 -translate-y-1/2 translate-x-1/2 rounded-full opacity-10 bg-gradient-to-br ${c.gradient}`}></div>
            <div class="relative z-10 p-8">
              <div class="flex items-center gap-4 mb-4">
                <div class={`inline-flex items-center justify-center w-14 h-14 rounded-xl text-white flex-shrink-0 bg-gradient-to-br ${c.gradient}`}>
                  <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 256 256"><path d={ICON_PATHS[product.data.icon]} /></svg>
                </div>
                <h3 class="text-xl font-bold text-gray-900 font-display">{product.data.title}</h3>
              </div>
              <p class="text-gray-600 leading-relaxed">{product.data.description}</p>
              <a href="/contact" class="inline-flex items-center gap-2 mt-6 text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
                Request Demo
                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 256 256"><path d="M221.66,133.66l-72,72a8,8,0,0,1-11.32-11.32L196.69,136H40a8,8,0,0,1,0-16H196.69L138.34,61.66a8,8,0,0,1,11.32-11.32l72,72A8,8,0,0,1,221.66,133.66Z" /></svg>
              </a>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
