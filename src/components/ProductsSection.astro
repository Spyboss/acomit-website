---
const products = [
  {
    title: "Business Inventory Management",
    description: "Track stock levels, manage suppliers, and get real-time inventory reports. Streamline your entire supply chain with our comprehensive management system.",
    icon: "boxes",
    color: "from-blue-500 to-blue-600",
  },
  {
    title: "Point of Sale Billing System",
    description: "Fast, reliable POS software for retail and wholesale businesses. Process sales, generate invoices, and track payments with ease.",
    icon: "credit-card",
    color: "from-green-500 to-green-600",
  },
  {
    title: "Welfare Management System",
    description: "Digital solution for managing employee welfare societies, loan tracking, member management, and financial reporting.",
    icon: "users",
    color: "from-orange-500 to-orange-600",
  },
  {
    title: "Credit Card Comparator",
    description: "Compare credit card features, interest rates, and benefits side-by-side. Help customers make informed financial decisions.",
    icon: "chart",
    color: "from-purple-500 to-purple-600",
  },
];

const iconMap = {
  boxes: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>',
  "credit-card": '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/></svg>',
  users: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z"/></svg>',
  chart: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z"/></svg>',
};
---

<section class="py-24 bg-gray-50" id="products">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto" data-aos="fade-up">
      <span class="inline-block px-4 py-1.5 text-sm font-medium rounded-full text-primary-700 bg-primary-100 mb-4">Our Products</span>
      <h2 class="section-title">Software Built for Sri Lankan Business</h2>
      <p class="section-subtitle mx-auto">
        Ready-to-deploy solutions that solve real problems. Used by businesses across the country.
      </p>
    </div>
    <div class="grid gap-8 mt-16 md:grid-cols-2">
      {products.map((product, index) => (
        <div
          class="group relative overflow-hidden rounded-2xl bg-white border border-gray-100 card-hover"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="absolute top-0 right-0 w-32 h-32 -translate-y-1/2 translate-x-1/2 rounded-full opacity-10 bg-gradient-to-br {product.color}"></div>
          <div class="relative z-10 p-8">
            <div class="inline-flex items-center justify-center w-14 h-14 rounded-xl text-white mb-5 bg-gradient-to-br {product.color}" set:html={iconMap[product.icon]}></div>
            <h3 class="text-xl font-bold text-gray-900 font-display mb-3">{product.title}</h3>
            <p class="text-gray-600 leading-relaxed">{product.description}</p>
            <a href="/contact" class="inline-flex items-center gap-2 mt-6 text-sm font-semibold text-primary-600 hover:text-primary-700 transition-colors">
              Request Demo
              <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
