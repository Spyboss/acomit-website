---
const services = [
  {
    title: "Software Solutions",
    description: "Custom software built on open-source platforms. POS systems, inventory management, and business automation tools tailored to your workflow.",
    icon: "code",
    features: ["Custom Development", "Open Source Platforms", "Business Automation", "System Integration"],
  },
  {
    title: "Web Solutions",
    description: "Modern, responsive websites, web applications, and reliable hosting. We design and develop your entire online presence.",
    icon: "globe",
    features: ["Web Design & Development", "Web Applications", "Web Hosting", "SEO Optimization"],
  },
  {
    title: "Mobile Solutions",
    description: "Android mobile applications and SMS-based platforms. Extend your business to customers on the go.",
    icon: "smartphone",
    features: ["Android Apps", "SMS Applications", "Mobile Web Platforms", "App Maintenance"],
  },
  {
    title: "Featured Products",
    description: "Ready-to-deploy solutions including inventory systems, POS billing, welfare management, and credit card comparison tools.",
    icon: "package",
    features: ["Inventory Systems", "POS Billing", "Welfare Management", "Financial Tools"],
  },
];

const iconMap = {
  code: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M10 20l4-16m4 4l4 4-4 4M6 16l-4-4 4-4"/></svg>',
  globe: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>',
  smartphone: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z"/></svg>',
  package: '<svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4"/></svg>',
};
---

<section class="py-24 bg-white" id="services">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto" data-aos="fade-up">
      <span class="inline-block px-4 py-1.5 text-sm font-medium rounded-full text-primary-700 bg-primary-100 mb-4">What We Do</span>
      <h2 class="section-title">Comprehensive IT Services</h2>
      <p class="section-subtitle mx-auto">
        From concept to deployment, we provide end-to-end technology solutions tailored for Sri Lankan businesses.
      </p>
    </div>
    <div class="grid gap-8 mt-16 md:grid-cols-2 lg:grid-cols-4">
      {services.map((service, index) => (
        <div
          class="group relative p-8 rounded-2xl bg-white border border-gray-100 card-hover"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="relative z-10">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-primary-100 text-primary-600 mb-6 group-hover:bg-primary-600 group-hover:text-white transition-all duration-300" set:html={iconMap[service.icon]}></div>
            <h3 class="text-xl font-bold text-gray-900 font-display mb-3">{service.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{service.description}</p>
            <ul class="space-y-2">
              {service.features.map((f) => (
                <li class="flex items-center gap-2 text-sm text-gray-500">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
