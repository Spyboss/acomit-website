---
import { getCollection } from "astro:content";
import { ICON_PATHS } from "../data/icons";

const services = (await getCollection("services")).sort((a, b) => a.data.order - b.data.order);
---

<section class="py-24 bg-white" id="services">
  <div class="max-w-7xl mx-auto px-4">
    <div class="text-center max-w-3xl mx-auto" data-aos="fade-up">
      <span class="inline-block px-4 py-1.5 text-sm font-medium rounded-full text-primary-700 bg-primary-100 mb-4">What We Do</span>
      <h2 class="section-title">Comprehensive IT Services</h2>
      <p class="section-subtitle mx-auto">
        From concept to deployment, we provide end-to-end technology solutions tailored for Sri Lankan businesses.
      </p>
    </div>
    <div class="grid gap-8 mt-16 md:grid-cols-2 lg:grid-cols-4">
      {services.map((service, index) => (
        <div
          class="group relative p-8 rounded-2xl bg-white border border-gray-100 card-hover"
          data-aos="fade-up"
          data-aos-delay={index * 100}
        >
          <div class="absolute inset-0 rounded-2xl bg-gradient-to-br from-primary-50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300"></div>
          <div class="relative z-10">
            <div class="inline-flex items-center justify-center w-16 h-16 rounded-xl bg-primary-100 text-primary-600 mb-6 group-hover:bg-primary-600 group-hover:text-white transition-all duration-300">
              <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 256 256"><path d={ICON_PATHS[service.data.icon]} /></svg>
            </div>
            <h3 class="text-xl font-bold text-gray-900 font-display mb-3">{service.data.title}</h3>
            <p class="text-gray-600 text-sm leading-relaxed mb-4">{service.data.description}</p>
            <ul class="space-y-2">
              {service.data.features.map((f: string) => (
                <li class="flex items-center gap-2 text-sm text-gray-500">
                  <svg class="w-4 h-4 text-primary-500 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/></svg>
                  {f}
                </li>
              ))}
            </ul>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
